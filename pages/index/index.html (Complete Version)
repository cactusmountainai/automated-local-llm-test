<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Home | Lane Smith Portfolio</title>
    <link href="../../styles/output.css" rel="stylesheet" />
    <script src="https://kit.fontawesome.com/a8cc471b41.js" crossorigin="anonymous"></script>
    <style>
      /* Hero Section Animation */
      @keyframes fadeUp {
        from {
          opacity: 0;
          transform: translateY(30px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      
      .animate-fade-up {
        animation: fadeUp 1s ease-out forwards;
      }
      
      .animate-delay-1 {
        animation-delay: 0.2s;
      }
      
      .animate-delay-2 {
        animation-delay: 0.4s;
      }
    </style>
  </head>

  <body class="dark:bg-gray-900 bg-slate-50 overflow-x-hidden">
    <!-- Hero Section -->
    <header class="w-full h-screen flex flex-col justify-center items-center px-6 sm:px-12 lg:px-24 bg-gradient-to-b from-blue-50 to-slate-50 dark:from-gray-900 dark:to-gray-800">
      <div class="max-w-4xl w-full text-center animate-fade-up">
        <!-- Lane Smith's Name -->
        <h1 class="hero-name mb-4 animate-delay-1">Lane Smith</h1>
        
        <!-- Professional Tagline -->
        <p class="hero-tagline mb-6 animate-delay-1">
          Creative Professional & Digital Designer
        </p>
        
        <!-- Professional Introduction -->
        <p class="hero-intro max-w-2xl mx-auto animate-delay-2">
          I am a passionate professional dedicated to crafting exceptional digital experiences. 
          With expertise in creative design, web development, and strategic thinking, 
          I help transform ideas into impactful realities. Let's collaborate to bring your vision to life.
        </p>
        
        <!-- Social Links / CTA -->
        <div class="mt-8 animate-delay-2">
          <a href="#about" class="inline-block bg-blue-600 hover:bg-blue-700 text-white font-medium py-3 px-8 rounded-lg transition duration-300 shadow-lg hover:shadow-xl">
            Explore My Work
          </a>
        </div>
      </div>
    </header>
    
    <!-- Main Content Area -->
    <main class="w-full min-h-screen">
      <!-- Portfolio/Projects Section -->
      <section id="portfolio" class="w-full py-24 px-6 sm:px-12 lg:px-24 dark:bg-gray-900 bg-slate-50">
        <div class="max-w-6xl mx-auto">
          <h2 class="text-3xl font-bold mb-12 text-center dark:text-white">Featured Work</h2>
          <!-- Projects would be listed here -->
        </div>
      </section>
    </main>
  </body>
</html>